@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

@prefix eudpp:   <http://dpp.taltech.ee/EUDPP#> .
@prefix lca:     <http://dpp.cea.fr/EUDPP/LCA#> .
@prefix si:      <https://si-digital-framework.org/SI#> .
@prefix dct:     <http://purl.org/dc/terms#> .

@prefix shapes:  <http://dpp.taltech.ee/EUDPP/shapes#> .

shapes:ProductShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Product ;
    rdfs:label "Product — compliance shape" ;

    sh:property [ sh:path eudpp:uniqueProductID ;
        sh:or ( [ sh:datatype xsd:anyURI ] [ sh:datatype xsd:string ] ) ;
        sh:message "uniqueProductID deve essere xsd:anyURI o xsd:string." ] ;

    sh:property [ sh:path eudpp:productName ;
        sh:datatype xsd:string ;
        sh:message "productName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:description ;
        sh:datatype xsd:string ;
        sh:message "description deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:GTIN ;
        sh:datatype xsd:string ;
        sh:message "GTIN deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:commodityCode ;
        sh:datatype xsd:string ;
        sh:message "commodityCode deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:productImage ;
        sh:datatype xsd:anyURI ;
        sh:message "productImage deve essere xsd:anyURI." ] ;

    sh:property [ sh:path eudpp:isEnergyRelated ;
        sh:datatype xsd:boolean ;
        sh:maxCount 1 ;
        sh:message "isEnergyRelated deve essere un singolo xsd:boolean." ] ;

    sh:property [ sh:path eudpp:hasDPP ;
        sh:class eudpp:DPP ;
        sh:message "hasDPP deve puntare a un'istanza di eudpp:DPP." ] ;

    sh:property [ sh:path eudpp:hasProperty ;
        sh:class eudpp:Property ;
        sh:message "hasProperty deve puntare a un'istanza di eudpp:Property." ] ;

    sh:property [ sh:path eudpp:hasProductGroup ;
        sh:class eudpp:ClassificationCode ;
        sh:message "hasProductGroup deve puntare a un'istanza di eudpp:ClassificationCode." ] ;

    sh:property [ sh:path eudpp:hasManufacturer ;
        sh:nodeKind sh:IRI ;
        sh:message "hasManufacturer deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:hasEconomicOperator ;
        sh:nodeKind sh:IRI ;
        sh:message "hasEconomicOperator deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:isComponentOf ;
        sh:class eudpp:Product ;
        sh:message "isComponentOf deve puntare a un'istanza di eudpp:Product." ] ;

    sh:property [ sh:path eudpp:isSparePartOf ;
        sh:class eudpp:Product ;
        sh:message "isSparePartOf deve puntare a un'istanza di eudpp:Product." ] ;

    sh:property [ sh:path eudpp:containsSubstanceOfConcern ;
        sh:nodeKind sh:IRI ;
        sh:message "containsSubstanceOfConcern deve essere un IRI." ] .


shapes:DPPShape
    a sh:NodeShape ;
    sh:targetClass eudpp:DPP ;
    rdfs:label "DPP — compliance shape" ;

    sh:property [ sh:path eudpp:uniqueDPPID ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "uniqueDPPID deve essere un singolo IRI (xsd:anyURI)." ] ;

    sh:property [ sh:path eudpp:schemaVersion ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "schemaVersion deve essere un singolo xsd:string." ] ;

    sh:property [ sh:path eudpp:status ;
        sh:in ( "Active" "Archived" ) ;
        sh:maxCount 1 ;
        sh:message "status deve essere 'Active' o 'Archived'." ] ;

    sh:property [ sh:path eudpp:granularity ;
        sh:in ( "batch" " batch" "model" "product" ) ;
        sh:maxCount 1 ;
        sh:message "granularity deve essere 'batch', 'model' o 'product'." ] ;

    sh:property [ sh:path eudpp:lastUpdate ;
        sh:datatype xsd:dateTimeStamp ;
        sh:maxCount 1 ;
        sh:message "lastUpdate deve essere un singolo xsd:dateTimeStamp." ] ;

    sh:property [ sh:path eudpp:validFrom ;
        sh:datatype xsd:dateTimeStamp ;
        sh:maxCount 1 ;
        sh:message "validFrom deve essere un singolo xsd:dateTimeStamp." ] ;

    sh:property [ sh:path eudpp:validUntil ;
        sh:datatype xsd:dateTimeStamp ;
        sh:maxCount 1 ;
        sh:message "validUntil deve essere un singolo xsd:dateTimeStamp." ] ;

    sh:property [ sh:path eudpp:facilityID ;
        sh:datatype xsd:string ;
        sh:message "facilityID deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:linkToPreviousDPP ;
        sh:datatype xsd:anyURI ;
        sh:message "linkToPreviousDPP deve essere xsd:anyURI." ] ;

    sh:property [ sh:path eudpp:hasIssuer ;
        sh:nodeKind sh:IRI ;
        sh:message "hasIssuer deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:hasBackUpCopyHost ;
        sh:nodeKind sh:IRI ;
        sh:message "hasBackUpCopyHost deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:appliesToProduct ;
        sh:class eudpp:Product ;
        sh:message "appliesToProduct deve puntare a un'istanza di eudpp:Product." ] .


shapes:ClassificationCodeShape
    a sh:NodeShape ;
    sh:targetClass eudpp:ClassificationCode ;
    rdfs:label "ClassificationCode — compliance shape" ;

    sh:property [ sh:path eudpp:codeValue ;
        sh:datatype xsd:string ;
        sh:message "codeValue deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:codeSet ;
        sh:datatype xsd:anyURI ;
        sh:message "codeSet deve essere xsd:anyURI." ] .


shapes:PropertyShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Property ;
    rdfs:label "Property — compliance shape" ;

    sh:property [ sh:path eudpp:dictionaryReference ;
        sh:datatype xsd:string ;
        sh:message "dictionaryReference deve essere xsd:string." ] .


shapes:QuantitativePropertyShape
    a sh:NodeShape ;
    sh:targetClass eudpp:QuantitativeProperty ;
    rdfs:label "QuantitativeProperty — compliance shape" ;

    sh:property [ sh:path eudpp:numericalValue ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:message "numericalValue deve essere un singolo xsd:decimal." ] ;

    sh:property [ sh:path eudpp:tolerance ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:message "tolerance deve essere un singolo xsd:double." ] ;

    # range dichiarato è si:MeasurementUnit ma gli individui SI non hanno @type
    # esplicito nei grafi tipici → si valida solo che sia un IRI
    sh:property [ sh:path eudpp:hasMeasurementUnit ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:message "hasMeasurementUnit deve essere un singolo IRI." ] .


shapes:DocumentShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Document ;
    rdfs:label "Document — compliance shape" ;

    sh:property [ sh:path eudpp:contentType ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "contentType deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:value ;
        sh:datatype xsd:string ;
        sh:message "value deve essere xsd:string." ] .


shapes:DigitalInstructionShape
    a sh:NodeShape ;
    sh:targetClass eudpp:DigitalInstruction ;
    rdfs:label "DigitalInstruction — compliance shape" ;

    sh:property [ sh:path eudpp:webLink ;
        sh:datatype xsd:anyURI ;
        sh:message "webLink deve essere xsd:anyURI." ] .


# =============================================================================
# ACTOR MODULE
# =============================================================================

shapes:ActorShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Actor ;
    rdfs:label "Actor — compliance shape" ;

    sh:property [ sh:path eudpp:actorName ;
        sh:datatype xsd:string ;
        sh:message "actorName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:electronicContact ;
        sh:datatype xsd:string ;
        sh:message "electronicContact deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:postalAddress ;
        sh:datatype xsd:string ;
        sh:message "postalAddress deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:registeredTradeName ;
        sh:datatype xsd:string ;
        sh:message "registeredTradeName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:registeredTrademark ;
        sh:datatype xsd:string ;
        sh:message "registeredTrademark deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:hasRole ;
        sh:class eudpp:Role ;
        sh:message "hasRole deve puntare a un'istanza di eudpp:Role." ] ;

    sh:property [ sh:path eudpp:usesFacility ;
        sh:class eudpp:Facility ;
        sh:message "usesFacility deve puntare a un'istanza di eudpp:Facility." ] ;

    sh:property [ sh:path eudpp:isResponsibleForProduct ;
        sh:nodeKind sh:IRI ;
        sh:message "isResponsibleForProduct deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:uniqueOperatorID ;
        sh:datatype xsd:string ;
        sh:message "uniqueOperatorID deve essere xsd:string." ] .


shapes:LegalPersonShape
    a sh:NodeShape ;
    sh:targetClass eudpp:LegalPerson ;
    rdfs:label "LegalPerson — compliance shape" ;

    # owl:disjointWith NaturalPerson
    sh:not [ sh:class eudpp:NaturalPerson ] ;
    sh:message "LegalPerson e NaturalPerson sono disgiunte." ;

    sh:property [ sh:path eudpp:isEstablishedIn ;
        sh:nodeKind sh:IRI ;
        sh:message "isEstablishedIn deve essere un IRI (dcterms:Location)." ] .


shapes:NaturalPersonShape
    a sh:NodeShape ;
    sh:targetClass eudpp:NaturalPerson ;
    rdfs:label "NaturalPerson — compliance shape" ;

    sh:property [ sh:path eudpp:isResidingIn ;
        sh:nodeKind sh:IRI ;
        sh:message "isResidingIn deve essere un IRI (dcterms:Location)." ] .


shapes:FacilityShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Facility ;
    rdfs:label "Facility — compliance shape" ;

    sh:property [ sh:path eudpp:uniqueFacilityID ;
        sh:datatype xsd:string ;
        sh:message "uniqueFacilityID deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:isUsedByActor ;
        sh:class eudpp:Actor ;
        sh:message "isUsedByActor deve puntare a un'istanza di eudpp:Actor." ] .


shapes:RoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:Role ;
    rdfs:label "Role — compliance shape" ;

    sh:property [ sh:path eudpp:isRoleOf ;
        sh:class eudpp:Actor ;
        sh:message "isRoleOf deve puntare a un'istanza di eudpp:Actor." ] .


# disjointness esplicite dell'ontologia

shapes:AuthorisedRepresentativeRoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:AuthorisedRepresentativeRole ;
    sh:not [ sh:class eudpp:ManufacturerRole ] ;
    sh:message "AuthorisedRepresentativeRole e ManufacturerRole sono disgiunte." .

shapes:DPPServiceProviderRoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:DPPServiceProviderRole ;
    sh:not [ sh:class eudpp:EconomicOperatorRole ] ;
    sh:message "DPPServiceProviderRole e EconomicOperatorRole sono disgiunte." .

shapes:IndependentOperatorRoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:IndependentOperatorRole ;
    sh:not [ sh:class eudpp:ManufacturerRole ] ;
    sh:message "IndependentOperatorRole e ManufacturerRole sono disgiunte." .

shapes:ConformityAssessmentBodyRoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:ConformityAssessmentBodyRole ;
    sh:property [ sh:path eudpp:isRoleOf ;
        sh:class eudpp:LegalPerson ;
        sh:message "ConformityAssessmentBodyRole può essere isRoleOf solo di LegalPerson." ] .

shapes:ConsumerRoleShape
    a sh:NodeShape ;
    sh:targetClass eudpp:ConsumerRole ;
    sh:property [ sh:path eudpp:isRoleOf ;
        sh:class eudpp:NaturalPerson ;
        sh:message "ConsumerRole può essere isRoleOf solo di NaturalPerson." ] .


# =============================================================================
# SUBSTANCES OF CONCERN MODULE
# =============================================================================

shapes:SubstanceOfConcernShape
    a sh:NodeShape ;
    sh:targetClass eudpp:SubstanceOfConcern ;
    rdfs:label "SubstanceOfConcern — compliance shape" ;

    sh:property [ sh:path eudpp:hasConcentration ;
        sh:class eudpp:Concentration ;
        sh:message "hasConcentration deve puntare a un'istanza di eudpp:Concentration." ] ;

    sh:property [ sh:path eudpp:hasThreshold ;
        sh:class eudpp:Threshold ;
        sh:message "hasThreshold deve puntare a un'istanza di eudpp:Threshold." ] ;

    sh:property [ sh:path eudpp:hasLifeCycleStage ;
        sh:nodeKind sh:IRI ;
        sh:message "hasLifeCycleStage deve essere un IRI." ] ;

    sh:property [ sh:path eudpp:nameCAS ;
        sh:datatype xsd:string ;
        sh:message "nameCAS deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:nameIUPAC ;
        sh:datatype xsd:string ;
        sh:message "nameIUPAC deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:numberCAS ;
        sh:datatype xsd:string ;
        sh:message "numberCAS deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:numberEC ;
        sh:datatype xsd:string ;
        sh:message "numberEC deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:otherName ;
        sh:datatype xsd:string ;
        sh:message "otherName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:abbreviation ;
        sh:datatype xsd:string ;
        sh:message "abbreviation deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:tradeName ;
        sh:datatype xsd:string ;
        sh:message "tradeName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:usualName ;
        sh:datatype xsd:string ;
        sh:message "usualName deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:substanceLocation ;
        sh:datatype xsd:string ;
        sh:message "substanceLocation deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:hasImpactOnEnvironment ;
        sh:datatype xsd:string ;
        sh:message "hasImpactOnEnvironment deve essere xsd:string." ] ;

    sh:property [ sh:path eudpp:hasImpactOnHumanHealth ;
        sh:datatype xsd:string ;
        sh:message "hasImpactOnHumanHealth deve essere xsd:string." ] .


# =============================================================================
# LCA & ENVIRONMENTAL FOOTPRINT MODULE
# =============================================================================

shapes:ImpactCategoryIndicatorShape
    a sh:NodeShape ;
    sh:targetClass lca:Impact_Category_Indicator ;
    rdfs:label "Impact_Category_Indicator — compliance shape" ;

    sh:property [ sh:path lca:has_unit ;
        sh:datatype xsd:string ;
        sh:message "lca:has_unit deve essere xsd:string." ] ;

    sh:property [ sh:path lca:ICI_assess_IC ;
        sh:class lca:Impact_Category ;
        sh:message "ICI_assess_IC deve puntare a un'istanza di lca:Impact_Category." ] ;

    sh:property [ sh:path lca:ICI_quantified_by_CF ;
        sh:class lca:Characterization_Factor ;
        sh:message "ICI_quantified_by_CF deve puntare a un'istanza di lca:Characterization_Factor." ] ;

    sh:property [ sh:path lca:ICI_computes_IR ;
        sh:class lca:Impact_potential_result ;
        sh:message "ICI_computes_IR deve puntare a un'istanza di lca:Impact_potential_result." ] .


shapes:ImpactPotentialResultShape
    a sh:NodeShape ;
    sh:targetClass lca:Impact_potential_result ;
    rdfs:label "Impact_potential_result — compliance shape" ;

    sh:property [ sh:path <http://qudt.org/schema/qudt#numericValue> ;
        sh:or (
            [ sh:datatype xsd:decimal ]
            [ sh:datatype xsd:double  ]
            [ sh:datatype xsd:float   ]
            [ sh:datatype xsd:integer ]
        ) ;
        sh:maxCount 1 ;
        sh:message "qudt:numericValue deve essere un singolo valore numerico." ] ;

    sh:property [ sh:path lca:IR_computed_by_ICI ;
        sh:class lca:Impact_Category_Indicator ;
        sh:message "IR_computed_by_ICI deve puntare a un'istanza di lca:Impact_Category_Indicator." ] ;

    sh:property [ sh:path lca:corresponds_to_IC ;
        sh:class lca:Impact_Category ;
        sh:message "corresponds_to_IC deve puntare a un'istanza di lca:Impact_Category." ] ;

    sh:property [ sh:path lca:corresponds_to ;
        sh:nodeKind sh:IRI ;
        sh:message "corresponds_to deve essere un IRI." ] .


shapes:CharacterizationFactorShape
    a sh:NodeShape ;
    sh:targetClass lca:Characterization_Factor ;
    rdfs:label "Characterization_Factor — compliance shape" ;

    sh:property [ sh:path lca:CF_quantifies_ICI ;
        sh:class lca:Impact_Category_Indicator ;
        sh:message "CF_quantifies_ICI deve puntare a un'istanza di lca:Impact_Category_Indicator." ] ;

    sh:property [ sh:path lca:CF_calculated_by_CM ;
        sh:class lca:Characterization_Model ;
        sh:message "CF_calculated_by_CM deve puntare a un'istanza di lca:Characterization_Model." ] .


shapes:CharacterizationModelShape
    a sh:NodeShape ;
    sh:targetClass lca:Characterization_Model ;
    rdfs:label "Characterization_Model — compliance shape" ;

    sh:property [ sh:path lca:CM_calculates_CF ;
        sh:class lca:Characterization_Factor ;
        sh:message "CM_calculates_CF deve puntare a un'istanza di lca:Characterization_Factor." ] ;

    sh:property [ sh:path lca:CM_used_in_method ;
        sh:class lca:Method ;
        sh:message "CM_used_in_method deve puntare a un'istanza di lca:Method." ] .


shapes:MethodShape
    a sh:NodeShape ;
    sh:targetClass lca:Method ;
    rdfs:label "Method — compliance shape" ;

    sh:property [ sh:path lca:method_uses_CM ;
        sh:class lca:Characterization_Model ;
        sh:message "method_uses_CM deve puntare a un'istanza di lca:Characterization_Model." ] ;

    sh:property [ sh:path lca:included_in ;
        sh:class lca:Methodology ;
        sh:message "included_in deve puntare a un'istanza di lca:Methodology." ] .


shapes:MethodologyShape
    a sh:NodeShape ;
    sh:targetClass lca:Methodology ;
    rdfs:label "Methodology — compliance shape" ;

    sh:property [ sh:path lca:includes ;
        sh:class lca:Method ;
        sh:message "includes deve puntare a un'istanza di lca:Method." ] ;

    sh:property [ sh:path lca:imposes ;
        sh:class lca:Impact_Category ;
        sh:message "imposes deve puntare a un'istanza di lca:Impact_Category." ] .


shapes:EnvironmentalFootprintShape
    a sh:NodeShape ;
    sh:targetClass lca:Environmental_Footprint ;
    rdfs:label "Environmental_Footprint — compliance shape" ;

    sh:property [ sh:path lca:quantifies ;
        sh:class lca:Environmental_Impact ;
        sh:message "quantifies deve puntare a un'istanza di lca:Environmental_Impact." ] ;

    sh:property [ sh:path lca:related_to ;
        sh:or (
            [ sh:class lca:Environmental_Footprint ]
            [ sh:class lca:Impact_Category ]
        ) ;
        sh:message "related_to deve puntare a Environmental_Footprint o Impact_Category." ] .


shapes:EnvironmentalImpactShape
    a sh:NodeShape ;
    sh:targetClass lca:Environmental_Impact ;
    rdfs:label "Environmental_Impact — compliance shape" ;

    sh:property [ sh:path lca:quantified_by ;
        sh:class lca:Environmental_Footprint ;
        sh:message "quantified_by deve puntare a un'istanza di lca:Environmental_Footprint." ] .